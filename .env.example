# OpenChamber Configuration
# Copy this file to .env and fill in your values.
# Docker Compose loads .env automatically from the project root.

# Port mapping (host:container, default: 3000)
# PORT=3000

# UI Password (required for external access)
# Generate with: openssl rand -base64 24
OPENCHAMBER_UI_PASSWORD=

# Bind address (default: 0.0.0.0)
# OPENCHAMBER_HOST=0.0.0.0

# External OpenCode server
# Connect to an existing OpenCode instance instead of starting a new one.
# OPENCODE_HOST=http://host.docker.internal:4096

# Skip starting the bundled OpenCode process
# Use when connecting to an external OpenCode server via OPENCODE_HOST.
# OPENCODE_SKIP_START=true

# OpenCode bind address (default: 127.0.0.1)
# OPENCHAMBER_OPENCODE_HOSTNAME=0.0.0.0
